---
import Base from './Base.astro';

const { title, description, nav, current } = Astro.props;
---
<Base title={`${title} - TraceYield docs`} description={description}>
  <div class="wrap docs">
    <aside class="docs-nav">
      {nav.map((group) => (
        <div class="docs-nav-group">
          <h4>{group.group}</h4>
          <ul>
            {group.items.map((d) => (
              <li>
                <a href={`/docs/${d.slug}`} aria-current={d.slug === current ? 'page' : undefined}>{d.title}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </aside>
    <article class="prose" data-pagefind-body>
      <slot />
    </article>
  </div>
</Base>
