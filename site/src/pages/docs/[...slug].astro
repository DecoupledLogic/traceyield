---
import { getCollection, render } from 'astro:content';
import Doc from '../../layouts/Doc.astro';
import { DOCS_NAV, flatDocs } from '../../docs-nav.mjs';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  const byId = new Map(entries.map((e) => [e.id, e]));
  return flatDocs().map((item) => {
    const entry = byId.get(item.id);
    if (!entry) {
      throw new Error(
        `docs-nav.mjs references id "${item.id}" but no such doc was loaded. ` +
          `Check the glob in content.config.ts and the id in docs-nav.mjs.`,
      );
    }
    return { params: { slug: item.slug }, props: { entry, item } };
  });
}

const { entry, item } = Astro.props;
const { Content } = await render(entry);
---
<Doc title={item.title} nav={DOCS_NAV} current={item.slug}>
  <Content />
</Doc>
