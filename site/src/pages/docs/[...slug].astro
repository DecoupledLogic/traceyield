---
import { getCollection, render } from 'astro:content';
import Doc from '../../layouts/Doc.astro';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  const sorted = entries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
  const nav = sorted.map((d) => ({ id: d.id, title: d.data.title, order: d.data.order ?? 99 }));
  return sorted.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, nav },
  }));
}

const { entry, nav } = Astro.props;
const { Content } = await render(entry);
---
<Doc title={entry.data.title} description={entry.data.description} docs={nav} current={entry.id}>
  <Content />
</Doc>
